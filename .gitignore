# Claude Code Runtime/Cache Directories
# These are automatically created by Claude Code during sessions
# and should not be committed to version control

# Accidental tilde directory (created when a script writes to ~/ inside the repo)
/~/

# AdditionalChecks folder (organized runtime directories)
/AdditionalChecks/

# Runtime directories (Claude Code may recreate these in repo root)
/shell-snapshots/
/session-env/
/.superpowers/
/debug/
/file-history/
/history.jsonl
/plans/
/projects/
/sessions/
/usage-data/
/paste-cache/
/telemetry/
/todos/
/statsig/
/plugins/
/chrome/
/.claude/plugins/
/social/

# macOS system files
.DS_Store

# Editor and workstation files
.idea/
.vscode/
*.swp
*.swo
*.tmp
*.temp
*.log
*.pid
*.orig
*.mp4
*.mov
*.avi
*.mkv
*.webm

# Runtime cache directories (recreated by hooks during sessions)
/tsc-cache/
/.claude/tsc-cache/
/.claude/runtime/
/.claude/skills/codex/.runtime/
/.claude/skills/super-ralph/.git/
/.claude/skills/chrome-devtools/scripts/node_modules/
/.claude/skills/chrome-devtools/scripts/docs/
/.claude/projects/
/.claude/file-history/
/.claude/history.jsonl
/.claude/statsig/
/.claude/debug/
/.claude/shell-snapshots/
/.claude/ide/
/.claude/plugins/
/.claude/todos/

# Session runtime state (machine-specific, contains paths and session IDs)
/.claude/homunculus/
/.claude/metrics/
/.claude/session-aliases.json
/.claude/session-data/

/tasks/
/cache/

# Deleted root-level AGENTS files (prevent re-creation)
/AGENTS-*.md

# Cache and state files
/mcp-needs-auth-cache.json
/stats-cache.json
/plugins/install-counts-cache.json
/plugins/installed_plugins.json
/plugins/known_marketplaces.json
/plugins/blocklist.json
/settings.local.json
/.claude/settings.local.json
/.env
/.env.*
/.credentials.json
/.credentials*.json
**/.env
**/.env.*
!**/.env.example
!**/.env.*.example
*.local
/.worktreeinclude
**/__pycache__/
**/*.pyc

# Image cache (not tracked)
/image-cache/


# Claude runtime state (session data, not user config)
/.claude.json
/.claude.json.backup*
/backups/
*.bak
*.bak.*
*.preremediation.*
/.claude/**/*.bak.*
/.claude/**/*.preremediation.*

# Generated lock files for local helper installs
.claude/skills/chrome-devtools/scripts/package-lock.json

# Per-project retake and local scripts (never commit from a consumer project)
/.claude/skills/chrome-devtools/scripts/retake_*.js
/.claude/skills/chrome-devtools/scripts/retake_*.cjs
/.claude/skills/chrome-devtools/scripts/*.local.js
/.claude/skills/chrome-devtools/scripts/*.local.cjs


# Settings file (contains machine-specific data)
/settings.json
!.claude/settings.json

# Local command/runtime artifacts
/.claude/checkpoints.log
/.claude/checkpoints/
/.claude/plan/
/.claude/scheduled_tasks.lock
/.claude/hooks/git-guard.sh
/.claude/hooks/session-rules-reinject.sh
/scripts/install.sh

# Node modules and lock files anywhere
**/node_modules/
**/bun.lock
**/bun.lockb
/package-lock.json
/yarn.lock





# API keys and example .env content. These are NOT real credentials.
# audit-secrets.py flags them as informational notes.

/memory/
**/MEMORY.md

# Remotion scaffolded video projects (created by the remotion skill)
/video/
**/out/*.mp4
**/out/*.webm
**/out/*.mov
**/.remotion/

# Additional runtime artifacts
*.sqlite
*.sqlite3
*.db
*.tsbuildinfo
.eslintcache
**/.eslintcache
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
coverage/
.coverage
htmlcov/

# OS files
Thumbs.db
Desktop.ini
._*

# ── Public sharing hardening ──

# Telemetry failed event NDJSON (contain email, session IDs, device IDs)
**/1p_failed_events.*.json

# Plugin orphan markers
**/.orphaned_at

# Credentials catch-all safety net
*.pem
*.key
credentials.json
secrets.*

# Database journal files
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm
*.db-journal

# ── Extended credential safety net ──

# SSH keys (no extension, caught by name)
id_rsa
id_ed25519
id_ecdsa
id_dsa

# Database and service credential files
.pgpass
.my.cnf
.htpasswd
.netrc
.npmrc

# Cloud platform credential files
service-account*.json
keyfile*.json
token.json

# Terraform state (contains plaintext secrets)
*.tfstate
*.tfstate.backup
terraform.tfvars
.terraform/

# Data dumps (PII risk)
*.sql
!**/migrations/*.sql
*.dump

# Skill runtime working files (safety net across all skills)
.claude/skills/**/workspace/
.claude/skills/**/PROGRESS.md
.claude/skills/**/.runtime/
.claude/skills/**/.agents/
.claude/skills/**/learnings.md
.claude/skills/**/__pycache__/
.claude/skills/**/*.pyc
.claude/skills/learned/
