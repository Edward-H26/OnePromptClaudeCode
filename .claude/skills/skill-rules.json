          "(how to|best practice|approach|method|methodology)",
          "(introduction|motivation|background|related work|approach|implementation|results|discussion|conclusion)",
          ".*?(abstract|literature review|findings|evaluation|analysis)",
          "(help me|can you).*?(write|explain|describe)"
        ]
