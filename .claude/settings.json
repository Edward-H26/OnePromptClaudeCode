{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 30,
  "env": {
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "32000",
    "MAX_THINKING_TOKENS": "32000",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_NO_FLICKER": "1",
    "AUTO_CODEX_TIMEOUT_SECONDS": "3600",
    "CLAUDE_CODE_EFFORT_LEVEL": "max",
    "BASH_DEFAULT_TIMEOUT_MS": "1800000",
    "BASH_MAX_TIMEOUT_MS": "7200000",
    "CLAUDE_STREAM_IDLE_TIMEOUT_MS": "1800000"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "includeGitInstructions": true,
  "permissions": {
    "allow": [
      "WebFetch(domain:github.com)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:medium.com)",
      "WebFetch(domain:m3.material.io)",
      "WebFetch(domain:www.radix-ui.com)",
      "WebFetch(domain:ui.shadcn.com)",
      "WebFetch(domain:deepwiki.com)",
      "WebFetch(domain:gist.github.com)",
      "WebFetch(domain:www.figma.com)",
      "WebFetch(domain:web.archive.org)",
      "WebSearch",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(cat:*)",
      "Bash(echo:*)",
      "Bash(printf:*)",
      "Bash(jq:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(du:*)",
      "Bash(cut:*)",
      "Bash(sort:*)",
      "Bash(paste:*)",
      "Bash(diff:*)",
      "Bash(readlink:*)",
      "Bash(realpath:*)",
      "Bash(ls:*)",
      "Bash(tree:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(test:*)",
      "Bash(lsof:*)",
      "Bash(stat:*)",
      "Bash(file:*)",
      "Bash(touch:*)",
      "Bash(date:*)",
      "Bash(pwd:*)",
      "Bash(tee:*)",
      "Bash(tr:*)",
      "Bash(xargs:*)",
      "Bash(basename:*)",
      "Bash(dirname:*)",
      "Bash(mktemp:*)",
      "Bash(sleep:*)",
      "Bash(nohup:*)",
      "Bash(open:*)",
      "Bash(env:*)",
      "Bash(source:*)",
      "Bash(command:*)",
      "Bash(type:*)",
      "Bash(bash:*)",
      "Bash(sh:*)",
      "Bash(rm:*)",
      "Bash(chmod:*)",
      "Bash(gh:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git fetch:*)",
      "Bash(git remote:*)",
      "Bash(git show:*)",
      "Bash(git blame:*)",
      "Bash(git rev-parse:*)",
      "Bash(git tag:*)",
      "Bash(git worktree:*)",
      "Bash(git ls-files:*)",
      "Bash(git ls-tree:*)",
      "Bash(git stash:*)",
      "Bash(git checkout:*)",
      "Bash(git config:*)",
      "Bash(git rm:*)",
      "Bash(git clean:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(mkdir:*)",
      "Bash(zip:*)",
      "Bash(unzip:*)",
      "Bash(curl:*)",
      "Bash(bundle exec:*)",
      "Bash(streamlit:*)",
      "Bash(sqlite3:*)",
      "Bash(iconv:*)",
      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(pnpm:*)",
      "Bash(yarn:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pip:*)",
      "Bash(pip3:*)",
      "Bash(pip install:*)",
      "Bash(pip3 install:*)",
      "Bash(pytest:*)",
      "Bash(uv:*)",
      "Bash(ruff:*)",
      "Bash(mypy:*)",
      "Bash(pyright:*)",
      "Bash(codex:*)",
      "Bash(claude:*)",
      "mcp__filesystem",
      "mcp__memory",
      "mcp__claude-in-chrome",
      "mcp__claude_ai_Figma",
      "mcp__playwright",
      "mcp__claude_ai_Hugging_Face",
      "mcp__plugin_context7_context7",
      "mcp__claude_ai_PDF_Viewer",
      "mcp__claude_ai_Scholar_Gateway",
      "mcp__claude_ai_Canva",
      "mcp__puppeteer",
      "mcp__plugin_playwright_playwright",
      "mcp__plugin_github_github",
      "Edit:*",
      "Write:*",
      "MultiEdit:*",
      "NotebookEdit:*"
    ],
    "deny": [
      "Bash(git commit:*)",
      "Bash(git commit)",
      "Bash(git push:*)",
      "Bash(git push)",
      "Bash(git reset --hard:*)",
      "Bash(rm -rf:*)",
      "Bash(rm -r:*)",
      "Bash(sudo:*)",
      "Bash(ssh:*)",
      "Bash(chmod 777:*)",
      "Bash(chmod -R 777:*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./.claude.json)",
      "Read(./.claude/settings.local.json)",
      "Read(./settings.json)",
      "Read(./history.jsonl)",
      "Read(./mcp-needs-auth-cache.json)",
      "Read(./backups/**)",
      "Read(./file-history/**)",
      "Read(./projects/**)",
      "Read(./session-env/**)",
      "Read(./sessions/**)",
      "Read(./.claude/runtime/**)",
      "Read(./.credentials.json)",
      "Bash(cat .env*)",
      "Bash(cat .credentials*)",
      "Bash(cat **/auth.json)"
    ],
    "ask": [
      "Bash(git merge:*)",
      "Bash(git rebase:*)",
      "Bash(git cherry-pick:*)"
    ],
    "defaultMode": "auto"
  },
  "enableAllProjectMcpServers": false,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_PLUGIN_DATA=\"~/.claude/runtime/gstack\" bash ~/.claude/skills/gstack/careful/bin/check-careful.sh",
            "statusMessage": "Checking careful mode..."
          }
        ]
      },
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_PLUGIN_DATA=\"~/.claude/runtime/gstack\" bash ~/.claude/skills/gstack/freeze/bin/check-freeze.sh",
            "statusMessage": "Checking freeze boundary..."
          }
        ]
      },
      {
        "matcher": "mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/check-mcp.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/task-orchestrator-hook.sh"
          },
          {
            "type": "command",
            "command": "AUTO_CODEX_HOME=\"~/.claude/runtime/codex/home\" AUTO_CODEX_RUNTIME_DIR=\"~/.claude/runtime/codex/runs\" ~/.claude/hooks/auto-codex-trigger.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/skill-activation-prompt.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/memory-bootstrap.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/post-tool-use-tracker.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/tsc-check.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/lint-check.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/workflow-step-tracker.sh"
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/workflow-step-tracker.sh"
          }
        ]
      },
      {
        "matcher": "mcp__claude-in-chrome__*|mcp__plugin_playwright_playwright__*|mcp__playwright__*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/workflow-step-tracker.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/stop-build-check-enhanced.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/workflow-completion-gate.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/session-end.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/pre-compact.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {},
  "outputStyle": "Explanatory",
  "alwaysThinkingEnabled": true,
  "promptSuggestionEnabled": true,
  "plansDirectory": "./plans"
}
