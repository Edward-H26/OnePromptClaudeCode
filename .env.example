# OnePromptClaudeCode Environment Variables
#
# Copy this file to .env and fill in the values you need.
# All variables are optional unless noted.

# Required for Codex bridge (auto-codex-trigger hook)
# OPENAI_API_KEY = "your-openai-api-key"

# Required for Anthropic API integrations (optional for most workflows)
# ANTHROPIC_API_KEY = "your-anthropic-api-key"

# Hook configuration (all optional, shown with defaults)
# AUTO_ERROR_THRESHOLD = 5
# CODEX_TIMEOUT = 120
